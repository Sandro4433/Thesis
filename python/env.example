# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit secrets.

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Model selection (optional — defaults shown) ────────────────────────────
# RC_MODEL=gpt-4.1
# RC_MAX_TOOL_ROUNDS=3

# ── Paths (optional — defaults relative to project root) ──────────────────
# RC_CONFIGURATION_PATH=configuration.json
# RC_SEQUENCE_PATH=sequence.json
# RC_CHANGES_PATH=changes.json
# RC_MEMORY_DIR=Memory
# RC_WORKSPACE_DIR=workspace

# ── Fast Downward planner ──────────────────────────────────────────────────
# Path to the fast-downward.py entry point.
# If using a git submodule at ./downward, the default works automatically.
# DOWNWARD_PATH=downward/fast-downward.py

# ── ROS / Franka workspace ─────────────────────────────────────────────────
# Absolute path to the devel/setup.bash of your catkin workspace.
# This is the Franka_Emika_Panda_Demo repo after running catkin build.
# REQUIRED for robot execution — the GUI sources this before launching
# any robot subprocess.
#
# Example:
# ROS_WS_PATH=/home/yourname/ws_franka/devel/setup.bash

